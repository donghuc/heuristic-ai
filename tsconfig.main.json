{
    "compilerOptions": {
        "target": "ES2017",
        "lib": [
            "ES2017"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": [
            "@figma/plugin-typings"
        ]
    },
    "include": [
        "src/main.ts",
        "src/rules/**/*",
        "src/shared/**/*",
        "src/services/**/*"
    ]
}